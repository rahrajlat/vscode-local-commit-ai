{
  "name": "local-commit-ai",
  "displayName": "Local Commit AI",
  "description": "Generate git commit messages using local LLMs (Ollama)",
  "version": "0.0.1",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:localCommitAI.generateCommit"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localCommitAI.generateCommit",
        "title": "⚡ Generate Commit Message"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "localCommitAI.generateCommit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "scm/inputBox": [
        {
          "command": "localCommitAI.generateCommit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Local Commit AI",
      "properties": {
        "localCommitAI.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API host URL"
        },
        "localCommitAI.model": {
          "type": "string",
          "default": "llama3.1",
          "description": "Ollama model to use"
        },
        "localCommitAI.promptTemplate": {
          "type": "string",
          "default": "",
          "description": "Custom prompt template (use {{diff}} placeholder)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
